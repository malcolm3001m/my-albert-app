# App
APP_NAME=My Albert API
APP_ENV=development
API_PREFIX=/api
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Albert API
ALBERT_BASE_URL=https://api-inside.albertschool.com
ALBERT_BEARER_TOKEN=replace_with_your_albert_token
ALBERT_HTTP_TIMEOUT_SECONDS=25
ALBERT_PROFILE_CACHE_TTL_SECONDS=300
ALBERT_DETAIL_CACHE_TTL_SECONDS=1800

# Optional offline/demo mode using the exported Albert JSON already in this workspace.
ALBERT_USE_FIXTURES=false
ALBERT_FIXTURES_DIR=../inside_export

# Google Calendar
GOOGLE_CALENDAR_ENABLED=false
# Point this at your OAuth client secret JSON. Keep that file in a gitignored location.
GOOGLE_CLIENT_SECRET_FILE=/absolute/path/to/client_secret.json
GOOGLE_TOKEN_FILE=.secrets/google_token.json
# Optional extra calendar IDs, comma-separated. Cohort Google calendar IDs are added automatically.
GOOGLE_CALENDAR_IDS=primary
GOOGLE_CALENDAR_LOOKAHEAD_DAYS=30
GOOGLE_MAX_RESULTS=50
GOOGLE_LOCAL_AUTH_PORT=8080

# Aggregation
PLANNER_LOOKAHEAD_DAYS=30
